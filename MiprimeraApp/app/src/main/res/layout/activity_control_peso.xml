<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".Control_peso">

    <!--Iniciamos con el scrollview que complemetara toda la pagina-->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#F0F4F8"
        android:fillViewport="true"
        android:padding="50dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- TextView del titulo principal -->
            <TextView
                android:id="@+id/txtVTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:text="Control de Peso"
                android:textColor="#1A4375"
                android:textSize="34sp"
                android:textStyle="bold" />

            <!-- TextView de edad  -->
            <TextView
                android:id="@+id/txtVsubtitle_edad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edad"
                android:textColor="#1A4375"
                android:textSize="16sp" />
            <!-- EditText Number para manejar los datos de entada -->

            <EditText
                android:id="@+id/txtNedad"
                style="@style/EditTextRounded"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Ej: 25"
                android:inputType="number"/>

            <!-- Incio de Peso con uso de LinerLayout Horizontal -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!--Text view de subtitulo peso-->
                <TextView
                    android:id="@+id/txtVsubtitle_peso"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Peso"
                    android:textColor="#1A4375"
                    android:textSize="16sp" />
                <!--Swich compat de peso unitario mas KG/LB-->
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swPesoUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1A4375"
                    android:text="KG / LB"
                    android:thumbTint="#1A4375"
                    android:trackTint="#1A4375"/>
            </LinearLayout>

            <EditText
                android:id="@+id/etPeso"
                style="@style/EditTextRounded"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Peso (kg)"
                android:inputType="numberDecimal"/>

            <!-- Inicio de calculo de Estatura  -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp">

                <!-- textView de subtitulo - Estatura   -->
                <TextView
                    android:id="@+id/txtVsubtitle_esttura"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Estatura"
                    android:textColor="#1A4375"
                    android:textSize="16sp" />

                <!-- switchcompat de comparacion de CM/IN   -->
                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/swEstaturaUnit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="#1A4375"
                    android:text="CM / IN"
                    android:thumbTint="#1A4375"
                    android:trackTint="#1A4375"/>
            </LinearLayout>

            <!-- Eit text de entada de datos, en este caso se ingresa la estatura -->
            <EditText
                android:id="@+id/etEstatura"
                style="@style/EditTextRounded"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:hint="Estatura (cm)"
                android:inputType="numberDecimal"/>

            <!-- Button para enviar los datos captados desde los EditTex Number -->
            <Button
                android:id="@+id/btnCalcular"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:text="CALCULAR"
                android:textStyle="bold"
                android:backgroundTint="#1A4375"
                android:textColor="#FFFFFF"
                app:cornerRadius="12dp"
                android:layout_marginBottom="32dp"
                android:layout_marginTop="24dp"/>

            <!-- card de resultados  -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <!-- Incio del orden de las cartas de forma vertical con uso de Linner layout-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Filas metricas -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <!-- Inicio de liner layout de resultados más subitutlos -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <!-- textView de subtitulo - IMC   -->
                            <TextView
                                android:id="@+id/txtVr_IMC"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="IMC"
                                android:textColor="#666"
                                android:textSize="12sp" />
                            <!-- textView de subtitulo - IMC para mostrar resultado   -->
                            <TextView
                                android:id="@+id/tvIMC"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#2E7D32"/>
                        </LinearLayout>

                        <!-- Incio de espacipo para el peso -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <!-- textView de subtitulo - Peso -->
                            <TextView
                                android:id="@+id/txtr_Peso"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Peso Ideal"
                                android:textColor="#666"
                                android:textSize="12sp" />

                            <!-- textView de subtitulo - Recibir los resultados de Peso Ideal-->
                            <TextView
                                android:id="@+id/tvPesoIdeal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#2E7D32"/>
                        </LinearLayout>

                        <!--Inicio de espacio para las cartas  -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">

                            <!-- textView de subtitulo - Grasa  -->
                            <TextView
                                android:id="@+id/txtr_grasa"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Grasa"
                                android:textColor="#666"
                                android:textSize="12sp" />

                            <!-- textView de para captar los resultados de grasa  -->
                            <TextView
                                android:id="@+id/tvGrasa"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="--"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:textColor="#2E7D32"/>
                        </LinearLayout>

                    </LinearLayout>

                    <!-- separador -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="12dp"
                        android:layout_marginBottom="12dp"
                        android:background="#DDDDDD"/>

                    <!-- resultados final -->
                    <TextView
                        android:id="@+id/tvClasificacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="Resultados"
                        android:textColor="#1A4375"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>